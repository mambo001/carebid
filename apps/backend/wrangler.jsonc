{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "carebid-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-19",
  "durable_objects": {
    "bindings": [
      {
        "name": "REQUEST_ROOM_DO",
        "class_name": "RequestRoomDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RequestRoomDurableObject"]
    }
  ],
  "vars": {
    "APP_NAME": "CareBid"
  }
}
