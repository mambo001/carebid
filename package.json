{
  "name": "carebid",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "deploy": "bun run build && wrangler deploy --config apps/backend/wrangler.jsonc && wrangler deploy --config apps/web/wrangler.jsonc",
    "db:generate": "bunx prisma generate --schema apps/backend/prisma/schema.prisma",
    "db:push": "bunx prisma db push --schema apps/backend/prisma/schema.prisma",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:restart": "docker compose restart",
    "infra:seed": "bun run --filter @carebid/backend seed",
    "infra:ps": "docker compose ps",
    "docker": "docker compose up --build --force-recreate"
  },
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "@prisma/adapter-neon": "^6.6.0",
    "@prisma/client": "^6.6.0",
    "@tanstack/react-query": "^5.75.4",
    "@vitejs/plugin-react": "^4.3.4",
    "effect": "^3.18.4",
    "final-form": "^5.0.0",
    "hono": "^4.8.5",
    "mui-rff": "^8.0.3",
    "@mui/material": "^7.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "prisma": "^6.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^4.1.2",
    "react-final-form": "^7.0.0",
    "react-router-dom": "^7.5.1",
    "vite": "^6.3.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
